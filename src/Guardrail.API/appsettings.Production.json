{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Auth": {
    "DisableAuth": true,
    "Audience": "guardrail-api"
  },
  "RateLimiting": {
    "PermitLimit": 30
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Providers": {
    "AzureContentSafety": {
      "UseHeuristicFallback": true
    },
    "AzurePromptShield": {
      "UseHeuristicFallback": true
    }
  },
  "Features": {
    "ContentSafetyEnabled": true,
    "PromptShieldEnabled": true,
    "HumanReviewEnabled": true,
    "EvaluationEnabled": true
  },
  "HuggingFace": {
    "Token": "",
    "ModelId": "Qwen/Qwen2.5-7B-Instruct-Turbo",
    "MaxTokens": 512,
    "Temperature": 0.7
  },
  "Guardrail": {
    "SeedDataOnStartup": true,
    "ApplyDatabaseOnStartup": true,
    "PolicySeedPath": "/app/policies/samples",
    "EvaluationSeedPath": "/app/evaluations/datasets"
  }
}
