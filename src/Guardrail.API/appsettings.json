{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "DisableAuth": false,
    "Authority": "https://your-identity-provider/.well-known/openid-configuration",
    "Audience": "guardrail-api"
  },
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Port=5432;Database=guardrail_db;Username=guardrail;Password=changeme",
    "Redis": "localhost:6379"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://admin.yourcompany.com"
    ]
  },
  "RateLimiting": {
    "PermitLimit": 100
  },
  "Providers": {
    "AzureContentSafety": {
      "Endpoint": "https://your-content-safety.cognitiveservices.azure.com/",
      "ApiKey": "",
      "ApiVersion": "2024-09-01",
      "UseHeuristicFallback": true
    },
    "AzurePromptShield": {
      "Endpoint": "https://your-content-safety.cognitiveservices.azure.com/",
      "ApiKey": "",
      "ApiVersion": "2024-09-01",
      "UseHeuristicFallback": true
    }
  },
  "KeyVault": {
    "Uri": "https://your-keyvault.vault.azure.net/"
  },
  "OpenTelemetry": {
    "ServiceName": "guardrail-api",
    "Endpoint": "http://localhost:4317"
  },
  "Features": {
    "ContentSafetyEnabled": true,
    "PromptShieldEnabled": true,
    "HumanReviewEnabled": true,
    "EvaluationEnabled": true
  },
  "HuggingFace": {
    "Token": "",
    "ModelId": "HuggingFaceH4/zephyr-7b-beta",
    "MaxTokens": 512,
    "Temperature": 0.7
  },
  "Guardrail": {
    "SeedDataOnStartup": true,
    "ApplyDatabaseOnStartup": true,
    "PolicyCacheMinutes": 15,
    "PolicySeedPath": "../../../../policies/samples",
    "EvaluationSeedPath": "../../../../evaluations/datasets"
  }
}
